{
  "name": "netflix-mail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:gui": "wrangler deploy --dry-run --outdir dist-gui",
    "types": "wrangler types",
    "check": "tsc --noEmit && vitest run",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply netflix_mail --local",
    "db:migrate:remote": "wrangler d1 migrations apply netflix_mail --remote"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "postal-mime": "^2.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
